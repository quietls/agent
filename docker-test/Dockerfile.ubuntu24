FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    ca-certificates curl openssl iproute2 lsb-release \
    nginx apache2 python3 \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /etc/nginx/ssl /etc/apache2/ssl

COPY nginx.conf /etc/nginx/sites-enabled/default
COPY apache.conf /etc/apache2/sites-enabled/000-default.conf

RUN openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
    -keyout /etc/nginx/ssl/nother.one.key \
    -out /etc/nginx/ssl/nother.one.crt \
    -subj "/CN=nother.one"

COPY ssl-agent-linux /usr/local/bin/ssl-agent
COPY mock-backend-linux /usr/local/bin/mock-backend
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/ssl-agent /usr/local/bin/mock-backend /usr/local/bin/entrypoint.sh

WORKDIR /app
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
